{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/web/(.*)", "destination": "/index.html" },
    { "source": "/web", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "/web/", "statusCode": 302 }
  ]
}
