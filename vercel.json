{
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/web/_expo/:path*", "destination": "/_expo/:path*" },
    { "source": "/web/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/web/manifest.json", "destination": "/manifest.json" },
    { "source": "/web/(.*)", "destination": "/index.html" },
    { "source": "/web", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "/web/", "statusCode": 302 }
  ]
}
